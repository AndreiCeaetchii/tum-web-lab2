---
export interface Props {
  quote: string;
  name: string;
  subject: string;
  initial: string;
}
const { quote, name, subject, initial } = Astro.props;
---
<div class="bg-light-bg rounded-lg p-6 sm:p-7 flex flex-col justify-between">
  <p class="text-sm sm:text-[0.97rem] leading-relaxed text-gray-800 mb-6 italic">
    &ldquo;{quote}&rdquo;
  </p>
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold">{initial}</div>
    <div>
      <strong class="block font-semibold text-sm">{name}</strong>
      <span class="text-xs text-gray-500" set:html={subject}></span>
    </div>
  </div>
</div>
