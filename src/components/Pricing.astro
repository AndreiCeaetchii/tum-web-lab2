---
import { getCollection } from 'astro:content';
import PricingCard from './PricingCard.astro';

const plans = (await getCollection('pricing')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="py-12 sm:py-16 md:py-20 bg-light-bg" id="pricing">
  <div class="max-w-[1140px] mx-auto px-4 sm:px-6">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-center mb-3">Simple, Transparent Pricing</h2>
    <p class="text-center text-gray-500 text-sm sm:text-base md:text-lg max-w-[560px] mx-auto mb-10 md:mb-12">
      Choose a plan that fits your learning needs. All plans include access to our online platform.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 items-start">
      {plans.map((plan) => (
        <PricingCard
          name={plan.data.name}
          price={plan.data.price}
          currency={plan.data.currency}
          period={plan.data.period}
          featured={plan.data.featured}
          features={plan.data.features}
          ctaLabel={plan.data.ctaLabel}
          ctaStyle={plan.data.ctaStyle}
        />
      ))}
    </div>
  </div>
</section>
