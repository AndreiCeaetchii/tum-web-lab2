---
import { getCollection } from 'astro:content';
import SubjectCard from './SubjectCard.astro';

const subjects = (await getCollection('subjects')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="py-12 sm:py-16 md:py-20" id="subjects">
  <div class="max-w-[1140px] mx-auto px-4 sm:px-6">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-center mb-3">Subjects We Cover</h2>
    <p class="text-center text-gray-500 text-sm sm:text-base md:text-lg max-w-[560px] mx-auto mb-10 md:mb-12">
      From exact sciences to humanities — our tutors are ready to help you excel.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {subjects.map(async (subject) => {
        const { Content } = await subject.render();
        return (
          <SubjectCard
            icon={subject.data.icon}
            title={subject.data.title}
            description={subject.body.trim()}
          />
        );
      })}
    </div>
  </div>
</section>
