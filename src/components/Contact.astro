---
export interface Props {
  email: string;
  phone: string;
  location: string;
}
const { email, phone, location } = Astro.props;
---
<section class="py-12 sm:py-16 md:py-20" id="contact">
  <div class="max-w-[1140px] mx-auto px-4 sm:px-6">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-center mb-3">Contact Us</h2>
    <p class="text-center text-gray-500 text-sm sm:text-base md:text-lg max-w-[560px] mx-auto mb-10 md:mb-12">
      Have questions or ready to get started? Reach out and we'll get back to you within 24 hours.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 items-start">
      <div>
        <div class="mb-6">
          <h4 class="text-base font-semibold text-gray-800 mb-1">&#9993; Email</h4>
          <p class="text-sm text-gray-500">{email}</p>
        </div>
        <div class="mb-6">
          <h4 class="text-base font-semibold text-gray-800 mb-1">&#9742; Phone</h4>
          <p class="text-sm text-gray-500">{phone}</p>
        </div>
        <div class="mb-6">
          <h4 class="text-base font-semibold text-gray-800 mb-1">&#9872; Location</h4>
          <p class="text-sm text-gray-500">{location}</p>
        </div>
      </div>
      <form class="flex flex-col gap-3.5" onsubmit="return false;">
        <input type="text" placeholder="Your Name" required class="px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 outline-none focus:border-primary focus:ring-2 focus:ring-blue-200 transition-all" />
        <input type="email" placeholder="Your Email" required class="px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 outline-none focus:border-primary focus:ring-2 focus:ring-blue-200 transition-all" />
        <textarea rows="5" placeholder="Your Message" required class="px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 outline-none resize-y focus:border-primary focus:ring-2 focus:ring-blue-200 transition-all"></textarea>
        <button type="submit" class="bg-primary text-white px-7 py-3 rounded-lg font-semibold hover:bg-primary-dark hover:shadow-lg transition-all cursor-pointer">Send Message</button>
      </form>
    </div>
  </div>
</section>
