---
import { getCollection } from 'astro:content';
import TestimonialCard from './TestimonialCard.astro';

const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="py-12 sm:py-16 md:py-20" id="testimonials">
  <div class="max-w-[1140px] mx-auto px-4 sm:px-6">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-center mb-3">What Our Students Say</h2>
    <p class="text-center text-gray-500 text-sm sm:text-base md:text-lg max-w-[560px] mx-auto mb-10 md:mb-12">
      Thousands of students across Moldova trust TutorMD for their learning goals.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {testimonials.map((t) => (
        <TestimonialCard
          quote={t.body.trim()}
          name={t.data.name}
          subject={t.data.subject}
          initial={t.data.initial}
        />
      ))}
    </div>
  </div>
</section>
