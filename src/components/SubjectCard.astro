---
export interface Props {
  icon: string;
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;
---
<div class="bg-white border border-gray-200 rounded-lg p-6 sm:p-8 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
  <span class="text-4xl block mb-4" set:html={icon}></span>
  <h3 class="text-lg font-semibold mb-2" set:html={title}></h3>
  <p class="text-sm text-gray-500 leading-relaxed">{description}</p>
</div>
