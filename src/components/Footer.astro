---
export interface Props {
  siteName: string;
  tagline: string;
  email: string;
  phone: string;
  location: string;
  copyrightYear: number;
}
const { siteName, tagline, email, phone, location, copyrightYear } = Astro.props;
---
<footer class="bg-gray-900 text-gray-300 pt-12 sm:pt-16">
  <div class="max-w-[1140px] mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr] gap-8 md:gap-10">
    <div>
      <a href="#" class="text-2xl font-bold text-white tracking-tight">{siteName}</a>
      <p class="mt-3 text-sm text-gray-400 leading-relaxed">{tagline}</p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-4">Quick Links</h4>
      <ul class="flex flex-col gap-2.5">
        <li><a href="#subjects" class="text-sm text-gray-400 hover:text-white transition-colors">Subjects</a></li>
        <li><a href="#how-it-works" class="text-sm text-gray-400 hover:text-white transition-colors">How It Works</a></li>
        <li><a href="#testimonials" class="text-sm text-gray-400 hover:text-white transition-colors">Testimonials</a></li>
        <li><a href="#pricing" class="text-sm text-gray-400 hover:text-white transition-colors">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-4">Contact Us</h4>
      <p class="text-sm text-gray-400 leading-loose">{email}</p>
      <p class="text-sm text-gray-400 leading-loose">{phone}</p>
      <p class="text-sm text-gray-400 leading-loose">{location}</p>
    </div>
  </div>
  <div class="mt-10 sm:mt-12 border-t border-gray-800 text-center text-sm text-gray-500 py-5">
    <div class="max-w-[1140px] mx-auto px-4 sm:px-6">
      <p>&copy; {copyrightYear} {siteName}. All rights reserved.</p>
    </div>
  </div>
</footer>
