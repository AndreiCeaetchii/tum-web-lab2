---
export interface Stat {
  value: string;
  label: string;
}
export interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---
<section class="block md:hidden bg-primary py-5 px-4">
  <div class="flex justify-around text-center max-w-[1140px] mx-auto">
    {stats.map((stat) => (
      <div>
        <strong class="block text-xl sm:text-2xl font-extrabold text-white">{stat.value}</strong>
        <span class="text-xs text-slate-300 uppercase tracking-wide">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
